# Docker Compose only.
# Copy this file to .env in the project root when running the app with Docker.
# Local non-Docker development uses backend/.env and frontend/.env.local instead.

# Frontend browser calls the backend through the host-mapped port.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Default Docker mode uses mock providers so the stack can start without API keys.
# set these when using real providers (gemini or deepseek)
LLM_PROVIDER_ANALYZER=mock
LLM_PROVIDER_EXPLAINER=mock
LLM_PROVIDER_TRANSLATOR=mock
LLM_PROVIDER_TEXT_GENERATOR=mock

GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-3.1-flash-lite

DEEPSEEK_API_KEY=your_key_here
DEEPSEEK_MODEL=deepseek-chat

OLLAMA_MODEL=qwen3:8b

OPENAI_API_KEY=your_key_here
OPENAI_MODEL=gpt-4o-mini

# Optional Langfuse observability.
LANGFUSE_PUBLIC_KEY=your_key_here
LANGFUSE_SECRET_KEY=your_key_here
LANGFUSE_BASE_URL="https://cloud.langfuse.com"
